# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session secret (random long string)
SESSION_SECRET=change-me-to-a-random-secret

# CORS: comma-separated list of allowed frontend origins (production)
ALLOWED_ORIGINS=https://your-app.vercel.app

# Port (optional, defaults to 3001 in dev / 5000 in prod)
PORT=3001

# Frontend: API base URL (set in Vercel environment variables)
# VITE_API_URL=https://your-backend.railway.app
